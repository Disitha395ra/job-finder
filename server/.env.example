# Server Port
PORT=5000

# Client URL for CORS (set to your deployed frontend URL for production)
# Local development: no need to set this
# Production example: https://job-finder-nu-gold.vercel.app
CLIENT_URL=

# Firebase Admin SDK - place serviceAccountKey.json in server root
# OR set these environment variables:
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
